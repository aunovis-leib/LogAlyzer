
    
    
    <Window x:Class="LogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogAnalyzer"
        xmlns:vm="clr-namespace:LogAnalyzer.ViewModels"
        xmlns:ctrls="clr-namespace:LogAnalyzer.Controls"
        xmlns:bh="clr-namespace:LogAnalyzer.Behaviors"
        xmlns:views="clr-namespace:LogAnalyzer.Views"
        xmlns:res="clr-namespace:LogAnalyzer.Resources"
        mc:Ignorable="d"
        Title="LogAlyzer" Height="450" Width="800" Icon="/Resources/Icons/LogAlyzer.png"
        PreviewMouseDown="Window_PreviewMouseDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate x:Key="LogListTemplate">
            <views:LogListView />
        </DataTemplate>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="ToggleButton.Checked" SourceName="SettingsToggle">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="SettingsPaneTransform"
                                     Storyboard.TargetProperty="X"
                                     To="0" Duration="0:0:0.2" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="ToggleButton.Unchecked" SourceName="SettingsToggle">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="SettingsPaneTransform"
                                     Storyboard.TargetProperty="X"
                                     To="420" Duration="0:0:0.2" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition>
                <RowDefinition.Style>
                    <Style TargetType="RowDefinition">
                        <Setter Property="Height" Value="1.2*" />
                        <Setter Property="MaxHeight" Value="Infinity" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Value="False"
                                               Binding="{Binding DataContext.SettingsVM.ShowPatternMatchPanel,
                                                                 RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Condition Value="False"
                                               Binding="{Binding DataContext.SettingsVM.ShowLiveChart,
                                                                 RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Condition Value="False"
                                               Binding="{Binding DataContext.ShowSearchResultsTab,
                                                                 RelativeSource={RelativeSource AncestorType=Window}}" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Height" Value="0" />
                                <Setter Property="MaxHeight" Value="0" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </RowDefinition.Style>
            </RowDefinition>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,0">
            <Button Command="{Binding AddListCommand}" BorderThickness="0" Background="{x:Null}">
                <Image Source="/Resources/Icons/Add_log-view.ico" Width="20" Height="20" />
            </Button>
                
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="Profil:" />
                <ComboBox ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          Width="100"
                          Margin="6,0,0,0" />

                <ctrls:DateRangePicker FromDate="{Binding FilterFromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       ToDate="{Binding FilterToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBox Margin="12,0,0,0"
                     MinWidth="160"
                     Width="220"
                     Style="{StaticResource WatermarkTextBoxStyle}"
                     ctrls:WatermarkService.Placeholder="Suche in allen Logs"
                     Text="{Binding GlobalSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Margin="6,0,0,0" Command="{Binding RunSearchCommand}">
                <TextBlock Text="Suchen" />
            </Button>

            <ToggleButton Margin="12,0,0,0"
                          Width="50"
                          Padding="10,2"
                          VerticalAlignment="Center"
                          IsChecked="{Binding SettingsVM.SyncSelectionAcrossLists, Mode=TwoWay}"
                          Content="Sync">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="Background" Value="#FFE6E6E6" />
                        <Setter Property="BorderBrush" Value="#FFBFBFBF" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FF9B0000" />
                                <Setter Property="Background" Value="#FFD62828" />
                                <Setter Property="BorderBrush" Value="#FF9B0000" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFD62828" BlurRadius="14" ShadowDepth="0" Opacity="0.9" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <ToggleButton x:Name="SettingsToggle" Margin="12,0,0,0" IsChecked="{Binding IsSettingsPaneOpen, Mode=TwoWay}">
                <Image Source="/Resources/Icons/Settings.ico" Width="20" Height="20" />
            </ToggleButton>
        </StackPanel>
        <Grid x:Name="LogListsHost" Grid.Row="2" />

        <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Height="6" VerticalAlignment="Center" ResizeDirection="Rows" Background="#33000000">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Value="False"
                                           Binding="{Binding DataContext.SettingsVM.ShowPatternMatchPanel,
                                                             RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Condition Value="False"
                                           Binding="{Binding DataContext.SettingsVM.ShowLiveChart,
                                                             RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Condition Value="False"
                                           Binding="{Binding DataContext.ShowSearchResultsTab,
                                                             RelativeSource={RelativeSource AncestorType=Window}}" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Collapsed" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <TabControl x:Name="BottomTabs" Grid.Row="4" Margin="0,8,0,0" Loaded="BottomTabs_Loaded">
            <TabControl.Style>
                <Style TargetType="TabControl">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Value="False"
                                           Binding="{Binding DataContext.SettingsVM.ShowPatternMatchPanel,
                                                             RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Condition Value="False"
                                           Binding="{Binding DataContext.SettingsVM.ShowLiveChart,
                                                             RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Condition Value="False"
                                           Binding="{Binding DataContext.ShowSearchResultsTab,
                                                             RelativeSource={RelativeSource AncestorType=Window}}" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Collapsed" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>

            <TabItem x:Name="PatternMatchTab"
                     Header="Pattern Match"
                     IsVisibleChanged="BottomTab_IsVisibleChanged"
                     Visibility="{Binding DataContext.SettingsVM.ShowPatternMatchPanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <views:PatternMatchPanelView DataContext="{Binding PatternMatchPanelVM}" />
            </TabItem>

            <TabItem x:Name="LiveChartTab"
                     Header="Live Chart"
                     IsVisibleChanged="BottomTab_IsVisibleChanged"
                     Visibility="{Binding DataContext.SettingsVM.ShowLiveChart, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <views:LiveChartView DataContext="{Binding ChartVM}" />
            </TabItem>

            <TabItem x:Name="SearchTab"
                     Header="Suche"
                     IsVisibleChanged="BottomTab_IsVisibleChanged"
                     Visibility="{Binding ShowSearchResultsTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ListView x:Name="SearchResultsListView"
                          ItemsSource="{Binding SearchResults}"
                          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                          Margin="8"
                          bh:ListViewBehaviors.FillRemainingColumnIndex="3"
                          bh:ListViewBehaviors.FillRemainingColumnMinWidth="120"
                          SelectionMode="Single"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="50" DisplayMemberBinding="{Binding LineNumber}" />
                            <GridViewColumn Header="Date" Width="160" DisplayMemberBinding="{Binding DateDisplay}" />
                            <GridViewColumn Header="Type" Width="90" DisplayMemberBinding="{Binding Type}" />
                            <GridViewColumn Header="Text" Width="500" DisplayMemberBinding="{Binding Text}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>

        <!-- Sliding Settings Pane -->
        <Border x:Name="SettingsPane" Grid.RowSpan="5" Width="320" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="1" HorizontalAlignment="Right" DataContext="{Binding SettingsVM}">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SettingsPaneTransform" X="420" />
            </Border.RenderTransform>
            <views:SettingsView />
        </Border>
    </Grid>
</Window>
