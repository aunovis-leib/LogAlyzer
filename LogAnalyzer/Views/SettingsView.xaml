<UserControl x:Class="LogAnalyzer.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:res="clr-namespace:LogAnalyzer.Resources"
             xmlns:conv="clr-namespace:LogAnalyzer.Converters"
             xmlns:ctrls="clr-namespace:LogAnalyzer.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        <conv:HexColorToBrushConverter x:Key="HexColorToBrushConverter" />
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{x:Static res:Strings.Settings}" FontWeight="Bold" FontSize="16" />
        <Separator Grid.Row="1" Margin="0,8,0,8" />
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
        <GroupBox Header="{x:Static res:Strings.List}">
            <StackPanel Margin="6">
                <CheckBox Content="{x:Static res:Strings.SyncSelectionAcrossLists}"
                          IsChecked="{Binding SyncSelectionAcrossLists, Mode=TwoWay}" />
                <CheckBox Content="{x:Static res:Strings.ShowFileExplorerInLogLists}" Margin="0,8,0,0"
                          IsChecked="{Binding ShowFileExplorerInLogLists, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock VerticalAlignment="Center" Text="{x:Static res:Strings.MaxEntriesPerList}" />
                    <TextBox Width="80" Margin="6,0,0,0" Text="{Binding MaxEntriesPerList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                    <TextBlock VerticalAlignment="Center" Text="{x:Static res:Strings.ExplorerRootFolder}" />
                    <DockPanel Margin="0,4,0,0">
                        <Button DockPanel.Dock="Right" Content="..." Width="28" Margin="6,0,0,0" Click="ChooseExplorerRootFolder_Click" />
                                <ComboBox ItemsSource="{Binding ExplorerRootFolderHistory, Mode=OneWay}"
                                  SelectedItem="{Binding ExplorerRootFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" />
                    </DockPanel>
                    <Button Content="{x:Static res:Strings.CurrentPathAsRoot}" Width="140" HorizontalAlignment="Left" Margin="0,6,0,0" Click="SetCurrentExplorerPathAsRoot_Click" />
                </StackPanel>
                <CheckBox Content="{x:Static res:Strings.AutoReloadLogFiles}" Margin="0,8,0,0"
                          IsChecked="{Binding AutoReloadLogFiles, Mode=TwoWay}" />
                <GroupBox Header="{x:Static res:Strings.DateColumnSorting}" Margin="0,8,0,0">
                    <StackPanel Margin="6">
                        <RadioButton Content="{x:Static res:Strings.NewestEntriesOnTopDescending}" Margin="0,4,0,0"
                                     IsChecked="{Binding DateSortDescending, Mode=TwoWay}" />
                        <RadioButton Content="{x:Static res:Strings.OldestEntriesOnTopAscending}" Margin="0,4,0,0"
                                     IsChecked="{Binding DateSortDescending, Mode=TwoWay, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </GroupBox>


        <GroupBox Header="{x:Static res:Strings.LiveChart}">
            <CheckBox Margin="6" Content="{x:Static res:Strings.ShowLiveChart}"
                  IsChecked="{Binding ShowLiveChart, Mode=TwoWay}" />
        </GroupBox>


        <GroupBox Header="{x:Static res:Strings.PatternMatchPanel}">
            <CheckBox Margin="6" Content="{x:Static res:Strings.ShowPatternMatchPanel}"
                  IsChecked="{Binding ShowPatternMatchPanel, Mode=TwoWay}" />
        </GroupBox>


        <GroupBox Header="{x:Static res:Strings.SynchronizationTolerance}" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock VerticalAlignment="Center" Margin="6,0,0,0" Text="{x:Static res:Strings.ToleranceHhMmSs}" />
                <TextBox Width="100" Margin="6,0,0,0" Text="{Binding SyncTolerance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{x:Static res:Strings.HighlightRules}" Margin="0,8,0,0">
            <StackPanel Margin="6">
                <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{x:Static res:Strings.SearchText}" Margin="0,0,0,2" FontSize="11" />
                        <TextBox Text="{Binding HighlightSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="24" />
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="0,6,0,0">
                        <TextBlock Text="{x:Static res:Strings.Color}" Margin="0,0,0,2" FontSize="11" />
                        <ctrls:SimpleColorPicker SelectedColor="{Binding HighlightColor, Mode=TwoWay}" />
                    </StackPanel>
                    <Button Content="{x:Static res:Strings.AddRule}" Command="{Binding AddHighlightRuleCommand}" Margin="0,6,0,0" Height="28" />
                </StackPanel>
                <TextBlock Text="{x:Static res:Strings.ActiveRules}" Margin="0,8,0,4" FontSize="11" FontWeight="Bold" />
                <DataGrid ItemsSource="{Binding HighlightRules}" MinHeight="100" MaxHeight="150"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserReorderColumns="False" CanUserResizeColumns="False"
                          ScrollViewer.VerticalScrollBarVisibility="Auto" AlternationCount="2">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="{x:Static res:Strings.Enabled}" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                        <DataGridTextColumn Header="{x:Static res:Strings.SearchText}" Binding="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        <DataGridTemplateColumn Header="{x:Static res:Strings.Color}" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Color, Converter={StaticResource HexColorToBrushConverter}}" 
                                            BorderBrush="#999" BorderThickness="1" Height="20" Margin="4,0,2,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ctrls:SimpleColorPicker SelectedColor="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                             Margin="0" Padding="0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{x:Static res:Strings.Remove}" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" Command="{Binding DataContext.RemoveHighlightRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" Padding="4,2" Margin="0" FontSize="11" Height="22" Width="32" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </GroupBox>

        <Button Content="{x:Static res:Strings.ResetDefaults}" Command="{Binding ResetDefaultsCommand}" HorizontalAlignment="Right" Width="120" Margin="0,12,0,0" />

        <Separator Margin="0,12,0,8" />
        <GroupBox Header="{x:Static res:Strings.LogPatternEditor}">
            <StackPanel Margin="6">
                <TextBlock Text="{x:Static res:Strings.ManageLogPatternTemplates}" FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Button Content="{x:Static res:Strings.OpenPatternEditor}" 
                        Command="{Binding OpenPatternEditorCommand}"
                        Padding="10,8"
                        Background="#007ACC"
                        Foreground="White"
                        FontWeight="Bold"/>
                <TextBlock Text="{x:Static res:Strings.CreateEditAndTestLogPatternTemplates}" 
                           FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
        </GroupBox>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
