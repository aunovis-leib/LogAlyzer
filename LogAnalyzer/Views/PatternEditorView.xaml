<UserControl x:Class="LogAnalyzer.Views.PatternEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LogAnalyzer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Pattern-Liste -->
        <Border Grid.Column="0" Background="#F5F5F5" BorderThickness="0,0,1,0" BorderBrush="#CCCCCC">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="10">
                    <TextBlock Text="Patterns" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Command="{Binding AddPatternCommand}" Padding="10" Content="+ Neues Pattern"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Patterns}"
                         SelectedItem="{Binding CurrentPattern}"
                         Margin="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Severity}" FontSize="11" Foreground="#666666"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Pattern Editor" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                <!-- Basis-Felder -->
                <TextBlock Text="ID" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CurrentPattern.Id}" Padding="8" Margin="0,0,0,15" IsReadOnly="True"/>

                <TextBlock Text="Name" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CurrentPattern.Name}" Padding="8" Margin="0,0,0,15"/>

                <TextBlock Text="Beschreibung" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CurrentPattern.Description}" Padding="8" TextWrapping="Wrap" Height="60" Margin="0,0,0,15"/>

                <!-- Regex Pattern -->
                <TextBlock Text="Regex Pattern" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CurrentPattern.RegexPattern}" 
                         Padding="8" 
                         TextWrapping="Wrap" 
                         Height="80"
                         FontFamily="Courier New"
                         Margin="0,0,0,15"
                         Background="#F9F9F9"/>

                <!-- Severity -->
                <TextBlock Text="Severity" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox SelectedItem="{Binding CurrentPattern.Severity}"
                          Padding="8"
                          Margin="0,0,0,15">
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">critical</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">error</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">warning</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">info</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">debug</System:String>
                </ComboBox>

                <!-- Priority -->
                <TextBlock Text="Priority" FontWeight="Bold" Margin="0,0,0,5"/>
                <Slider Value="{Binding CurrentPattern.Priority}" 
                        Minimum="0" 
                        Maximum="200"
                        Margin="0,0,0,15"/>
                <TextBlock Text="{Binding CurrentPattern.Priority}" Foreground="#999999"/>

                <!-- Test -->
                <Border Background="#E3F2FD" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Test Pattern" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="Testzeile:" FontSize="11" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding TestLine, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,10"
                                 Height="60"
                                 TextWrapping="Wrap"/>

                        <Button Command="{Binding TestPatternCommand}" Padding="10,5" Content="Test ausführen" Margin="0,0,0,10"/>

                        <TextBlock Text="Ergebnis:" FontSize="11" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TestResult}"
                                   Padding="8"
                                   Background="White"
                                   Foreground="#333333"
                                   TextWrapping="Wrap"
                                   Height="100"/>
                    </StackPanel>
                </Border>

                <!-- Speichern/Löschen -->
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Command="{Binding SavePatternCommand}" 
                            Padding="15,10" 
                            Background="#4CAF50"
                            Foreground="White"
                            Margin="0,0,10,0"
                            Content="Speichern"/>
                    <Button Command="{Binding DeletePatternCommand}" 
                            Padding="15,10" 
                            Background="#F44336"
                            Foreground="White"
                            Content="Löschen"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
