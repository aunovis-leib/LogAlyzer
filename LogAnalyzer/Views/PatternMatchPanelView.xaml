<UserControl x:Class="LogAnalyzer.Views.PatternMatchPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LogAnalyzer.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Background="#F0F0F0">
        <DockPanel>
            <!-- Header mit Filterleiste -->
            <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="10">
                <StackPanel>
                    <TextBlock Text="Pattern Matches" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Suchfeld -->
                        <TextBox Grid.Column="0"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Background="White"
                                 Foreground="Black"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0"/>

                        <!-- Severity-Filter -->
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Severities}"
                                  SelectedItem="{Binding SelectedSeverity}"
                                  Padding="8"
                                  Background="White"
                                  Margin="5,0,5,0"/>

                        <!-- Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="5,0,0,0">
                            <Button Command="{Binding PinSelectedCommand}"
                                    Padding="8,5"
                                    Margin="0,0,2,0"
                                    ToolTip="Pinned/Unpin">📌</Button>
                            <Button Command="{Binding UnpinAllCommand}"
                                    Padding="8,5"
                                    Margin="0,0,2,0"
                                    ToolTip="Unpin All">🔓</Button>
                            <Button Command="{Binding ExportCommand}"
                                    Padding="8,5"
                                    Margin="0,0,2,0"
                                    ToolTip="Export CSV">📥</Button>
                            <Button Command="{Binding ClearAllCommand}"
                                    Padding="8,5"
                                    ToolTip="Clear All">🗑️</Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Matches-Liste -->
            <ListBox DockPanel.Dock="Top"
                     ItemsSource="{Binding Matches}"
                     SelectedItem="{Binding SelectedMatch}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Background="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Pin-Indicator -->
                                <TextBlock Grid.Column="0" 
                                           Text="📌" 
                                           Margin="0,0,8,0"
                                           Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>

                                <!-- Severity-Indicator -->
                                <Rectangle Grid.Column="1"
                                           Width="4"
                                           Margin="0,0,10,0"
                                           Fill="{Binding SeverityColor}"/>

                                <!-- Inhalt -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontWeight="Bold" 
                                               Text="{Binding Match.Pattern.Name}"
                                               Foreground="{Binding SeverityColor}"/>
                                    <TextBlock Text="{Binding DisplayText}" 
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#666666"
                                               Margin="0,5,0,0"
                                               FontSize="12"/>

                                    <!-- Extrahierte Felder -->
                                    <ItemsControl ItemsSource="{Binding Match.ExtractedFields}"
                                                  Margin="0,5,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E8F4F8" Padding="4,2" Margin="0,0,5,0" CornerRadius="3">
                                                    <TextBlock Foreground="#000080" FontSize="11">
                                                        <Run Text="{Binding Key}" FontWeight="Bold"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding Value}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Statusbar -->
            <Border DockPanel.Dock="Bottom" Background="#E8E8E8" Padding="10">
                <TextBlock>
                    <Run Text="Matches: "/>
                    <Run Text="{Binding Matches.Count}"/>
                    <Run Text=" | Pinned: "/>
                    <Run Text="{Binding Matches.Count}"/>
                </TextBlock>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
