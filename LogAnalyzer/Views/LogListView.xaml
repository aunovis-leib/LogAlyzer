<UserControl x:Class="LogAnalyzer.Views.LogListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:LogAnalyzer.Converters"
             xmlns:models="clr-namespace:LogAnalyzer.Models"
             xmlns:views="clr-namespace:LogAnalyzer.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:ctrls="clr-namespace:LogAnalyzer.Controls"
             xmlns:bh="clr-namespace:LogAnalyzer.Behaviors"
             xmlns:res="clr-namespace:LogAnalyzer.Resources"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:AddOneConverter x:Key="AddOne" />
        <conv:LogTypeStringToNullableConverter x:Key="LogTypeStringToNullableConverter" />
        <conv:HexColorToBrushConverter x:Key="HexColorToBrushConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <ContextMenu x:Key="LogEntryContextMenu">
            <MenuItem Header="{x:Static res:Strings.Synchronize}"
                      Command="{Binding PlacementTarget.DataContext.SelectEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="{x:Static res:Strings.CopyText}"
                      Command="{Binding PlacementTarget.DataContext.CopyEntryTextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="{x:Static res:Strings.ApplyAsGlobalSearch}"
                      Click="ApplyGlobalSearchFromSelection_Click" />
            <Separator />
            <MenuItem Header="{x:Static res:Strings.AddToPattern}"
                      Command="{Binding PlacementTarget.DataContext.AddToPatternCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator />
            <MenuItem Header="{x:Static res:Strings.AddRule}"
                      Command="{Binding PlacementTarget.DataContext.AddHighlightRuleFromEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>

        <ContextMenu x:Key="LogDetailContextMenu">
            <MenuItem Header="{x:Static res:Strings.ApplySelectionAsFilter}"
                      Command="{Binding PlacementTarget.Tag.ApplyFilterTextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="{x:Static res:Strings.ApplySelectionAsGlobalSearch}"
                      Command="{Binding PlacementTarget.Tag.ApplyGlobalSearchTextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto">
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="Auto" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.SettingsVM.ShowFileExplorerInLogLists, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="Width" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="8">
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="8" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.SettingsVM.ShowFileExplorerInLogLists, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="Width" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="41*" />
            <ColumnDefinition Width="139*"/>
        </Grid.ColumnDefinitions>

        <views:FileExplorerView Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                Visibility="{Binding DataContext.SettingsVM.ShowFileExplorerInLogLists, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                DataContext="{Binding FileExplorerVM}" />
        <GridSplitter Grid.Row="0"
                      Grid.RowSpan="3"
                      Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      Visibility="{Binding DataContext.SettingsVM.ShowFileExplorerInLogLists, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                      ShowsPreview="True" />

        <Grid Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button HorizontalAlignment="Left" Command="{Binding ChooseFileCommand}" BorderThickness="0" Background="{x:Null}">
                    <Image Width="20" Height="20" Source="/Resources/Icons/Add-files.ico" />
                </Button>
                <ctrls:DateRangePicker Margin="8,0,0,0"
                                       FromDate="{Binding FilterFromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       ToDate="{Binding FilterToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Margin="8,0,0,0"
                         Width="70"
                         Style="{StaticResource WatermarkTextBoxStyle}"
                         ctrls:WatermarkService.Placeholder="HH:mm:ss"
                         Text="{Binding FilterFromTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                         bh:TimeInputBehavior.IsEnabled="True"
                         ToolTip="Von Uhrzeit (HH:mm:ss)" />
                <TextBlock Margin="4,0,0,0" Text="bis" VerticalAlignment="Center" />
                <TextBox Margin="4,0,0,0"
                         Width="70"
                         Style="{StaticResource WatermarkTextBoxStyle}"
                         ctrls:WatermarkService.Placeholder="HH:mm:ss"
                         Text="{Binding FilterToTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                         bh:TimeInputBehavior.IsEnabled="True"
                         ToolTip="Bis Uhrzeit (HH:mm:ss)" />
                <TextBox Margin="8,0,0,0"
                         MinWidth="90"
                         Width="90"
                         Style="{StaticResource WatermarkTextBoxStyle}"
                         ctrls:WatermarkService.Placeholder="Filtertext"
                         Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Margin="8,0,0,0"
                          Width="80"
                          IsEditable="True"
                          Text="{Binding SelectedType, Mode=OneWay, Converter={StaticResource LogTypeStringToNullableConverter}}"
                          ItemsSource="{Binding AvailableTypes}"
                          SelectedItem="{Binding SelectedType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource LogTypeStringToNullableConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Margin="8,0,0,0" Command="{Binding CancelLoadingCommand}" IsEnabled="{Binding IsLoading}">
                    <TextBlock Text="Abbrechen" />
                </Button>
            </StackPanel>
            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Command="{Binding DataContext.RemoveListCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    BorderThickness="0"
                    Background="{x:Null}"
                    ToolTip="LogView entfernen">
                <TextBlock Text="✕" FontSize="14" FontWeight="Bold" />
            </Button>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <ListView x:Name="LogsListView" ItemsSource="{Binding LogFilesView}" SelectedItem="{Binding SelectedEntry, Mode=TwoWay}" bh:ListViewBehaviors.ScrollToItem="{Binding SelectedEntry}"
                      bh:ListViewBehaviors.FillRemainingColumnIndex="3"
                      bh:ListViewBehaviors.FillRemainingColumnMinWidth="120"
                      ContextMenu="{StaticResource LogEntryContextMenu}"
                      SelectionMode="Extended"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.CacheLength="1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.IsDeferredScrollingEnabled="True"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                <ListView.Resources>
                    <Style x:Key="MiniMapTrackRepeatButton" TargetType="RepeatButton">
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="IsTabStop" Value="False" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="MiniMapLineButton" TargetType="RepeatButton">
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="IsTabStop" Value="False" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Background="#11000000">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="MiniMapThumb" TargetType="Thumb">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="#59808080"
                                            BorderBrush="#80606060"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            MinHeight="16"
                                            MinWidth="16" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <ControlTemplate x:Key="VerticalMiniMapScrollBar" TargetType="ScrollBar">
                        <Grid Background="#12000000">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0" Height="14" Content="▲" FontSize="8"
                                          Command="ScrollBar.LineUpCommand" Style="{StaticResource MiniMapLineButton}" />
                            <Grid Grid.Row="1">
                                <ctrls:LogMiniMap Entries="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  SourceListView="{Binding RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  MinimumMarkerHeight="1.2"
                                                  Panel.ZIndex="1"
                                                  Visibility="{Binding DataContext.SettingsVM.ShowMiniMap, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Track x:Name="PART_Track" IsDirectionReversed="True" Panel.ZIndex="0">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource MiniMapTrackRepeatButton}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource MiniMapTrackRepeatButton}" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource MiniMapThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <RepeatButton Grid.Row="2" Height="14" Content="▼" FontSize="8"
                                          Command="ScrollBar.LineDownCommand" Style="{StaticResource MiniMapLineButton}" />
                        </Grid>
                    </ControlTemplate>

                    <ControlTemplate x:Key="HorizontalScrollBar" TargetType="ScrollBar">
                        <Grid Background="#08000000">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <RepeatButton Grid.Column="0" Width="14" Content="◄" FontSize="8"
                                          Command="ScrollBar.LineLeftCommand" Style="{StaticResource MiniMapLineButton}" />
                            <Track Grid.Column="1" x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{StaticResource MiniMapTrackRepeatButton}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand" Style="{StaticResource MiniMapTrackRepeatButton}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MiniMapThumb}" />
                                </Track.Thumb>
                            </Track>
                            <RepeatButton Grid.Column="2" Width="14" Content="►" FontSize="8"
                                          Command="ScrollBar.LineRightCommand" Style="{StaticResource MiniMapLineButton}" />
                        </Grid>
                    </ControlTemplate>

                    <Style TargetType="ScrollBar">
                        <Setter Property="Template" Value="{StaticResource VerticalMiniMapScrollBar}" />
                        <Style.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="16" />
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="14" />
                                <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Resources>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <EventSetter Event="MouseLeftButtonUp" Handler="ListViewItem_MouseLeftButtonUp"/>
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListViewItem_PreviewMouseRightButtonDown"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <StackPanel>
                                        <Border x:Name="RowBorder" Padding="2,1" Background="{Binding HighlightColor, Converter={StaticResource HexColorToBrushConverter}}">
                                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                                  Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" />
                                        </Border>
                                        <ItemsControl x:Name="DetailRows"
                                                      Visibility="Collapsed"
                                                      Margin="36,2,8,6"
                                                      ItemsSource="{Binding Detail}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#22000000" BorderThickness="2,0,0,0" Padding="8,1,0,1">
                                                        <TextBox Text="{Binding Mode=OneWay}"
                                                                 Foreground="#6B6B6B"
                                                                 FontSize="12"
                                                                 TextWrapping="Wrap"
                                                                 IsReadOnly="True"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Padding="0"
                                                                 Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                 ContextMenu="{StaticResource LogDetailContextMenu}"
                                                                 PreviewMouseLeftButtonUp="DetailTextBox_PreviewMouseLeftButtonUp" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsDetailVisible}" Value="True">
                                            <Setter TargetName="DetailRows" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background" Value="#14007ACC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Header="#" Width="30"
                            DisplayMemberBinding="{Binding LineNumber}" />
                        <GridViewColumn DisplayMemberBinding="{Binding DateDisplay}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Date" Click="GridViewColumnHeader_Click" Tag="Date" />
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn DisplayMemberBinding="{Binding Type}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Type" Click="GridViewColumnHeader_Click" Tag="Type" />
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn DisplayMemberBinding="{Binding Text}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Text" Click="GridViewColumnHeader_Click" Tag="Text" />
                            </GridViewColumn.Header>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <StatusBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding LoadingStatus}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding FilteredEntryCount, StringFormat=Gefilterte Einträge: {0:N0}}" />
            </StatusBarItem>
            <Separator Visibility="{Binding HasNewEntries, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <StatusBarItem Visibility="{Binding HasNewEntries, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button Command="{Binding ClearNewEntriesNotificationCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#0078D4"
                        Padding="4,2"
                        Cursor="Hand">
                    <TextBlock>
                        <Run Text="✓ "/>
                        <Run Text="{Binding NewEntriesCount, Mode=OneWay}"/>
                        <Run Text=" neue Einträge verfügbar"/>
                    </TextBlock>
                </Button>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>